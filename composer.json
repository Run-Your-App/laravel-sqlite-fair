{
    "name": "run-your-app/laravel-sqlite-fair",
    "description": "Fair process coordination for Laravel applications backed by SQLite.",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*",
        "illuminate/database": ">=12.61.1 <13.0",
        "illuminate/support": ">=12.61.1 <13.0"
    },
    "require-dev": {
        "laravel/framework": ">=12.61.1 <13.0",
        "larastan/larastan": "^3.10",
        "orchestra/testbench": "^10.9",
        "pestphp/pest": "^4.4.1",
        "pestphp/pest-plugin-laravel": "^4.1",
        "phpstan/phpstan": "^2.2"
    },
    "autoload": {
        "psr-4": {
            "RunYourApp\\LaravelSqliteFair\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RunYourApp\\LaravelSqliteFair\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "RunYourApp\\LaravelSqliteFair\\Laravel\\FairSQLiteServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "lock": false,
        "sort-packages": true
    },
    "scripts": {
        "test": "@php vendor/bin/pest",
        "analyse": "@php vendor/bin/phpstan analyse --configuration=phpstan.neon",
        "review": [
            "@composer validate --strict",
            "@test",
            "@analyse"
        ]
    }
}
